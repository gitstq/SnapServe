# SnapServe Environment Configuration
# Copy this file to .env and modify as needed

# Server
SNAPSERVE_HOST=0.0.0.0
SNAPSERVE_PORT=8199
SNAPSERVE_WORKERS=1
SNAPSERVE_DEBUG=false

# API Authentication (leave empty to disable)
SNAPSERVE_API_KEY=
SNAPSERVE_API_KEY_HEADER=X-API-Key
SNAPSERVE_RATE_LIMIT_PER_MINUTE=60

# Storage
SNAPSERVE_OUTPUT_DIR=./snapserve_output
SNAPSERVE_KEEP_FILES_HOURS=24

# Browser
SNAPSERVE_BROWSER_HEADLESS=true
SNAPSERVE_BROWSER_WIDTH=1280
SNAPSERVE_BROWSER_HEIGHT=720
SNAPSERVE_CONCURRENT_BROWSERS=5
SNAPSERVE_PAGE_LOAD_TIMEOUT=30

# Screenshot defaults
SNAPSERVE_SCREENSHOT_FORMAT=png
SNAPSERVE_SCREENSHOT_QUALITY=80

# PDF defaults
SNAPSERVE_PDF_FORMAT=A4
SNAPSERVE_PDF_PRINT_BACKGROUND=true

# OG Image defaults
SNAPSERVE_OG_WIDTH=1200
SNAPSERVE_OG_HEIGHT=630

# Security
SNAPSERVE_ALLOWED_ORIGINS=["*"]
SNAPSERVE_BLOCKED_HOSTS=["localhost","127.0.0.1","0.0.0.0"]
